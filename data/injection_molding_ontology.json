{
  "dataset_name": "synthetic_injection_molding_demo",
  "domain_description": "Synthetic but realistic injection molding production intervals for demonstrating causal discovery, root-cause analysis, and counterfactual simulation in a manufacturing context.",
  "row_granularity": "One row equals one 30-minute production interval for one machine, one mold, one product variant, and one resin lot.",
  "target_variable": "scrap_rate_pct",
  "primary_business_question": "What operational, environmental, material, and tooling factors are causing scrap in injection molding, and which controllable levers reduce it most effectively?",
  "key_causal_pathways": [
    "ambient_humidity_pct -> dryer_dewpoint_c -> resin_moisture_pct -> defect_type=splay_moisture -> scrap_rate_pct",
    "mold_temperature_c + cooling_time_s -> warpage risk -> scrap_rate_pct",
    "maintenance_days_since_last -> calibration_drift_index -> process instability -> scrap_rate_pct",
    "tool_wear_index + injection_pressure_bar + clamp_force_kn -> flash risk -> scrap_rate_pct",
    "resin_batch_quality_index + barrel_temperature_c + injection_pressure_bar -> short_shot risk -> scrap_rate_pct",
    "operator_shift -> calibration_drift_index / operator_experience_level -> cooling_time_s and stability -> scrap_rate_pct"
  ],
  "suggested_demo_questions": [
    "What are the top causal drivers of scrap_rate_pct?",
    "Why does scrap increase during humid intervals?",
    "How much would scrap change if dryer_dewpoint_c were kept below -38 degC?",
    "What is the expected effect of increasing cooling_time_s by 1.5 seconds on warpage-heavy variants?",
    "Does maintenance_days_since_last affect scrap directly or mainly through calibration drift?",
    "Which machines are more sensitive to tool wear and high pressure?",
    "How do resin moisture and mold temperature interact?",
    "What changes reduce scrap without sharply increasing cycle time or energy?"
  ],
